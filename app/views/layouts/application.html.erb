<!-- app/views/layouts/application.html.erb -->
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Wil App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# --- 任意: ページ個別で <head> に何か差し込みたいとき --- %>
    <%= yield :head %>

    

    <%# --- Favicon / アイコン --- %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# --- CSS（Bootstrap → アプリCSSの順で「上書きしやすく」） --- %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel: "stylesheet" %>
    <%# app/assets/stylesheets の論理名。あなたの構成に合わせて "application" or :app を使用 %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <%# --- JS (Importmap) --- %>
    <%= javascript_importmap_tags %>

    <%# 🚫 直書きの jQuery は削除。使う場合は Importmap で pin してください。 %>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%# --- 共通ヘッダー（Bootstrap Navbar は _header.html.erb に） --- %>
    <%= render "layouts/header" %>

    <%# --- Flash（Bootstrapアラート対応・閉じるボタン付き） --- %>
    <div class="container mt-3">
      <% flash.each do |key, message| %>
        <%# Rails の key を Bootstrap のクラスにマップ %>
        <% bs_class =
             case key.to_s
             when "notice" then "success"
             when "alert"  then "danger"
             else key
             end %>
        <div class="alert alert-<%= bs_class %> alert-dismissible fade show" role="alert">
          <%= message %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div>

    <%# --- メインコンテンツ --- %>
    <main class="flex-grow-1">
      <div class="container py-4">
        <%= yield %>
      </div>
    </main>

    <%# --- 任意: フッター --- %>
    <footer class="mt-auto py-4 bg-light">
      <div class="container text-center text-muted small">
        &copy; <%= Time.current.year %> Wil App
      </div>
    </footer>

    <%# --- ページ末尾に差し込みたいスクリプト用スロット --- %>
    <%= yield :body_end %>
  </body>
</html>
